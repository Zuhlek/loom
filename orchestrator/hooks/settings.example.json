{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR/loom/hooks/resume-on-start.sh\"" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR/loom/hooks/validate-subagent-output.sh\"" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR/loom/hooks/auto-advance.sh\"" },
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR/loom/hooks/usage-stop.sh\"" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR/loom/hooks/usage-task-pre.sh\"" },
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR/loom/hooks/capture-task-start.sh\"" }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR/loom/hooks/usage-read-pre.sh\"" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task|Write|Edit|MultiEdit|AskUserQuestion",
        "hooks": [
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR/loom/hooks/emit-events.sh\"" },
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR/loom/hooks/usage-task-post.sh\"" }
        ]
      }
    ]
  }
}
