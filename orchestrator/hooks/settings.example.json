{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "\"$HOME/.claude/loom-hooks/resume-on-start.sh\"" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "\"$HOME/.claude/loom-hooks/pin-on-weave.sh\"" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          { "type": "command", "command": "\"$HOME/.claude/loom-hooks/validate-subagent-output.sh\"" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "\"$HOME/.claude/loom-hooks/auto-advance.sh\"" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "\"$HOME/.claude/loom-hooks/refresh-artifacts.sh\"" },
          { "type": "command", "command": "python3 \"$HOME/.claude/loom-hooks/board-transition.py\"" }
        ]
      },
      {
        "matcher": "Agent|Task",
        "hooks": [
          { "type": "command", "command": "python3 \"$HOME/.claude/loom-hooks/../lib/telemetry/tag-subagent-phase.py\"" }
        ]
      }
    ]
  }
}
