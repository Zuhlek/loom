{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "\"$HOME/.claude/loom-hooks/resume-on-start.sh\"" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          { "type": "command", "command": "\"$HOME/.claude/loom-hooks/validate-subagent-output.sh\"" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "\"$HOME/.claude/loom-hooks/auto-advance.sh\"" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          { "type": "command", "command": "\"$HOME/.claude/loom-hooks/capture-task-start.sh\"" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task|Write|Edit|MultiEdit|AskUserQuestion",
        "hooks": [
          { "type": "command", "command": "\"$HOME/.claude/loom-hooks/emit-events.sh\"" }
        ]
      }
    ]
  }
}
