{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loom.local/schemas/events.schema.json",
  "title": "Loom events.jsonl envelope",
  "type": "object",
  "required": ["ts", "project", "type", "payload"],
  "additionalProperties": false,
  "properties": {
    "ts": { "type": "string", "format": "date-time" },
    "project": { "type": "string", "minLength": 1 },
    "type": {
      "type": "string",
      "enum": [
        "project-created",
        "phase-started",
        "phase-completed",
        "phase-failed",
        "quality-check-completed",
        "quality-decision",
        "question-asked",
        "question-answered",
        "file-written",
        "subagent-dispatched",
        "subagent-returned",
        "pipeline-completed",
        "error"
      ]
    },
    "phase": {
      "type": ["string", "null"],
      "enum": [null, "spec", "design", "plan", "build", "review", "quality-check"]
    },
    "correlation-id": { "type": ["string", "null"] },
    "payload": { "type": "object" }
  }
}
