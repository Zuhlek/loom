{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loom.local/schemas/pipeline.schema.json",
  "title": "Loom pipeline.md parsed state",
  "type": "object",
  "required": [
    "Project name",
    "Current phase",
    "Phase status",
    "Produced artifacts",
    "Next valid action",
    "Resume point"
  ],
  "additionalProperties": true,
  "properties": {
    "Project name": { "type": "string", "minLength": 1 },
    "Ticket ID": { "type": "string" },
    "Type hint": { "type": "string" },
    "Current phase": {
      "type": "string",
      "enum": ["idea", "design", "plan", "build", "review"]
    },
    "Phase status": {
      "type": "string",
      "enum": ["Pending", "blocked", "failed", "complete"]
    },
    "Produced artifacts": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "Pending user input": { "type": "string" },
    "Quality findings": { "type": "string" },
    "Next valid action": { "type": "string" },
    "Resume point": { "type": "string" },
    "History": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["timestamp", "phase", "status", "note"],
        "properties": {
          "timestamp": { "type": "string" },
          "phase": { "type": "string" },
          "status": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    }
  }
}
