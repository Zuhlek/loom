{
  "name": "loom",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "dev:server": "tsx watch apps/server/src/index.ts",
    "dev:web": "pnpm --filter @loom/web exec vite",
    "start": "tsx apps/server/src/index.ts",
    "test": "vitest run",
    "build:web": "pnpm --filter @loom/web exec vite build",
    "install-hooks": "tsx scripts/install-hooks.ts",
    "reset-state": "tsx scripts/reset-state.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  }
}
